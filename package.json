{
  "name": "@aegis-monitor/monorepo",
  "version": "0.0.0",
  "description": "Aegis Monitor - TypeScript/JavaScript SDK for LLM evaluation and governance",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm-run-all --parallel build:*",
    "build:core": "npm run build --workspace=@aegis-monitor/core",
    "build:adapters": "npm run build --workspace=@aegis-monitor/adapters",
    "build:scorers": "npm run build --workspace=@aegis-monitor/scorers",
    "build:cost": "npm run build --workspace=@aegis-monitor/cost",
    "build:regression": "npm run build --workspace=@aegis-monitor/regression",
    "build:cli": "npm run build --workspace=@aegis-monitor/cli",
    "test": "npm-run-all test:unit test:integration",
    "test:unit": "npm-run-all test:unit:*",
    "test:unit:core": "npm run test --workspace=@aegis-monitor/core",
    "test:unit:adapters": "npm run test --workspace=@aegis-monitor/adapters",
    "test:unit:scorers": "npm run test --workspace=@aegis-monitor/scorers",
    "test:unit:cost": "npm run test --workspace=@aegis-monitor/cost",
    "test:unit:regression": "npm run test --workspace=@aegis-monitor/regression",
    "test:unit:cli": "npm run test --workspace=@aegis-monitor/cli",
    "test:integration": "vitest run --config tests/vitest.config.ts",
    "test:integration:watch": "vitest watch --config tests/vitest.config.ts",
    "test:integration:coverage": "vitest run --coverage --config tests/vitest.config.ts",
    "docs:api": "typedoc",
    "docs:check": "npm run docs:api",
    "release:verify-packages": "node scripts/release/verify-packages.mjs",
    "release:qa": "npm run lint && npm run format:check && npm run type-check && npm run build && npm run test && npm audit --audit-level=high",
    "release:prepare": "npm run release:qa && npm run release:verify-packages && npm run docs:api",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "lint": "eslint packages --ext .ts,.tsx",
    "format": "prettier --write packages/**/*.ts packages/**/*.json",
    "format:check": "prettier --check packages/**/*.ts packages/**/*.json",
    "type-check": "tsc --noEmit",
    "clean": "npm-run-all --parallel clean:*",
    "clean:core": "npm run clean --workspace=@aegis-monitor/core",
    "clean:adapters": "npm run clean --workspace=@aegis-monitor/adapters",
    "clean:scorers": "npm run clean --workspace=@aegis-monitor/scorers",
    "clean:cost": "npm run clean --workspace=@aegis-monitor/cost",
    "clean:regression": "npm run clean --workspace=@aegis-monitor/regression",
    "clean:cli": "npm run clean --workspace=@aegis-monitor/cli",
    "prepare": "husky install 2>/dev/null || true"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typedoc": "^0.27.6",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "npm-run-all2": "^6.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "husky": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
