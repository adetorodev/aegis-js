{
  "name": "@aegis-monitor/adapters",
  "version": "0.0.1",
  "description": "LLM provider adapters for Aegis Monitor",  "license": "MIT",  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "llm",
    "adapters",
    "openai",
    "anthropic",
    "google"
  ],
  "author": "Aegis Monitor",
  "license": "MIT",
  "peerDependencies": {
    "@aegis-monitor/core": "file:../core"
  },
  "devDependencies": {
    "@aegis-monitor/core": "file:../core",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "openai": "^4.0.0",
    "@anthropic-ai/sdk": "^0.7.0",
    "@google/generative-ai": "^0.1.0"
  },
  "optionalDependencies": {
    "openai": "^4.0.0",
    "@anthropic-ai/sdk": "^0.7.0",
    "@google/generative-ai": "^0.1.0"
  }
}
