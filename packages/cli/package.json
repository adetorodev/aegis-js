{
  "name": "@aegis-monitor/cli",
  "version": "0.0.1",
  "description": "CLI for Aegis Monitor LLM evaluation",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aegis-monitor": "dist/cli.cjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --sourcemap",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "llm",
    "cli",
    "evaluation",
    "testing"
  ],
  "author": "Aegis Monitor",
  "license": "MIT",
  "dependencies": {
    "@aegis-monitor/core": "file:../core",
    "@aegis-monitor/adapters": "file:../adapters",
    "@aegis-monitor/scorers": "file:../scorers",
    "@aegis-monitor/cost": "file:../cost",
    "@aegis-monitor/regression": "file:../regression",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "tsx": "^4.0.0"
  }
}
