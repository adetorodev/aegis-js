{
  "name": "@aegis-ai/regression",
  "version": "0.0.1",
  "description": "Regression detection and baseline management for Aegis AI",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "llm",
    "regression",
    "baseline",
    "evaluation"
  ],
  "author": "Aegis AI",
  "license": "MIT",
  "peerDependencies": {
    "@aegis-ai/core": "workspace:^0.0.1"
  },
  "devDependencies": {
    "@aegis-ai/core": "workspace:^0.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
