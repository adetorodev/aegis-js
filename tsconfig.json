{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@aegis-monitor/core": ["packages/core/src/index.ts"],
      "@aegis-monitor/core/*": ["packages/core/src/*"],
      "@aegis-monitor/adapters": ["packages/adapters/src/index.ts"],
      "@aegis-monitor/adapters/*": ["packages/adapters/src/*"],
      "@aegis-monitor/scorers": ["packages/scorers/src/index.ts"],
      "@aegis-monitor/scorers/*": ["packages/scorers/src/*"],
      "@aegis-monitor/cost": ["packages/cost/src/index.ts"],
      "@aegis-monitor/cost/*": ["packages/cost/src/*"],
      "@aegis-monitor/regression": ["packages/regression/src/index.ts"],
      "@aegis-monitor/regression/*": ["packages/regression/src/*"],
      "@aegis-monitor/cli": ["packages/cli/src/index.ts"],
      "@aegis-monitor/cli/*": ["packages/cli/src/*"]
    }
  },
  "include": ["packages/*/src/**/*.ts"]
}
